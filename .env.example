# Photo Pipeline Configuration
# Copy this file to .env and fill in your paths:
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────

# Primary Google Takeout export directory (the big one)
PRIMARY_DIR=/path/to/primary/GooglePhotos

# Output directory — where event album folders will be created
# Phase 8 creates symlinks here pointing back to PRIMARY_DIR/SECONDARY_DIR
FINAL_DIR=/path/to/output/final-google-photos

# ── Optional ──────────────────────────────────────────────────────────────

# Secondary Google Takeout export (e.g. a copy with enriched EXIF metadata)
# Leave blank if you only have one source
SECONDARY_DIR=

# Pipeline working directory (DB, logs, scripts)
# Defaults to the directory containing the scripts
PIPELINE_DIR=

# GeoNames data file for offline reverse geocoding
# Download: https://download.geonames.org/export/dump/allCountries.zip
GEONAMES_FILE=/path/to/allCountries.txt

# ── AI / Ollama ───────────────────────────────────────────────────────────

# Ollama server (default: local)
OLLAMA_HOST=http://localhost:11434

# Vision model for photo classification (Phase 6)
VISION_MODEL=llama3.2-vision:latest

# Text model for event naming (Phase 7.5)
TEXT_MODEL=gemma3:4b
